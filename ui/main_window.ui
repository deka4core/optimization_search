           <property name="styleSheet">
            <string notr="true">QScrollBar:vertical, QPlainTextEdit QScrollBar:vertical {
    background-color: #2d2d2d;
    width: 14px;
    border-radius: 7px;
    margin: 0px;
}
QScrollBar::handle:vertical, QPlainTextEdit QScrollBar::handle:vertical {
    background-color: #4d4d4d;
    min-height: 20px;
    border-radius: 7px;
    margin: 2px;
}

QTextEdit QScrollBar::handle:vertical:hover, QPlainTextEdit QScrollBar::handle:vertical:hover {
    background-color: #0078d4;
}

QScrollBar::add-line:vertical, QPlainTextEdit QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical, QPlainTextEdit QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}</string>
