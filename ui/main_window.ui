     <string notr="true">QLineEdit {
    background-color: #2d2d2d;
    border: 2px solid #404040;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 14px;
    color: #e0e0e0;
    selection-background-color: #0078d4;
    selection-color: #ffffff;
    min-height: 20px;
}

QLineEdit:hover {
    border-color: #505050;
    background-color: #333333;
}

QLineEdit:focus {
    border-color: #0078d4;
    background-color: #1e1e1e;
}

QLineEdit:disabled {
    background-color: #1a1a1a;
    border-color: #333333;
    color: #666666;
}

QTabWidget {
    background-color: transparent;
}

QTabWidget::pane {
    background-color: #1e1e1e;
    border: 2px solid #333333;
    border-radius: 8px;
    border-top-left-radius: 0px;
    margin-top: -1px;
}

QTabBar::tab {
    background-color: #2d2d2d;
    color: #cccccc;
    padding: 8px 16px;
    margin-right: 2px;

    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border: 1px solid #333333;
    border-bottom: none;

    font-size: 13px;
    font-weight: 500;
    min-width: 80px;
}

QTabBar::tab:hover {
    background-color: #3d3d3d;
    color: #ffffff;
    border-color: #0078d4;
}

QTabBar::tab:selected {
    background-color: #1e1e1e;
    color: #ffffff;
    border-color: #0078d4;
    border-bottom-color: #1e1e1e;
    margin-bottom: -1px;
    font-weight: 600;
}

QWidget#tab1, QWidget#tab2 {
    background-color: #1e1e1e;
    border: none;
}
</string>
